{
  "name": "faktorio-monorepo",
  "private": true,
  "workspaces": [
    "faktorio-api",
    "faktorio-fe",
    "faktorio-db",
    "faktorio-public-api"
  ],
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "npm-check-updates": "^21.0.3",
    "oxlint": "^1.61.0",
    "prettier": "^3.8.3",
    "turbo": "^2.9.6",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev:fe": "cd faktorio-fe && pnpm dev",
    "dev:api": "cd faktorio-api && pnpm dev",
    "dev:e2e:api": "cd faktorio-api && pnpm dev:e2e",
    "dev:e2e:sqld": "cd faktorio-db && pnpm start-sqld",
    "dev": "npm-run-all --parallel dev:fe dev:api",
    "dev:e2e": "npm-run-all --parallel dev:e2e:sqld dev:fe dev:e2e:api",
    "kill": "kill -9 $(lsof -t -i:9189)",
    "lint": "oxlint",
    "format": "prettier --write .",
    "dbg": "cd faktorio-api && pnpm generate",
    "dbm": "cd faktorio-api && pnpm migrate",
    "bumpDeps:api": "cd faktorio-api && ncu -u",
    "bumpDeps:fe": "cd faktorio-fe && ncu -u",
    "bump": "turbo bump && npm-check-updates -u && pnpm i",
    "typecheck": "turbo tsc",
    "test": "turbo test",
    "test:e2e": "pnpm exec playwright test --max-failures=1"
  },
  "resolutions": {
    "@react-pdf/image": "3.0.4"
  },
  "dependencies": {
    "dayjs": "^1.11.20",
    "npm-run-all": "^4.1.5",
    "superjson": "^2.2.6",
    "zod": "^4.3.6"
  }
}